pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git url: 'https://github.com/prasadprasii0803/jenkins-simple-demo.git'
            }
        }

        stage('Run Script') {
            steps {
                sh 'chmod +x script.sh'
                sh './script.sh'
            }
        }
    }
}pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git url: 'https://github.com/prasadprasii0803/jenkins-simple-demo.git'
            }
        }

        stage('Check Files') {
            steps {
                sh 'ls -l'
            }
        }

        stage('Run Script') {
            steps {
                sh 'chmod +x script.sh'
                sh './script.sh'
            }
        }
    }
}
